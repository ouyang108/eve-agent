{"type":"tool.run_safe_command","detail":{"command":"node -e \"\nconst fs = require('fs');\nconst path = require('path');\n\nconst excludeDirs = new Set(['node_modules', '.git', '.eve', '.history', '.workflow-data']);\n\nfunction searchDir(dir, patterns) {\n  const results = [];\n  try {\n    const entries = fs.readdirSync(dir, {withFileTypes: true});\n    for (const e of entries) {\n      const full = path.join(dir, e.name);\n      if (e.isDirectory()) {\n        if (!excludeDirs.has(e.name)) {\n          results.push(...searchDir(full, patterns));\n        }\n      } else if (e.isFile() && (e.name.endsWith('.ts') || e.name.endsWith('.js') || e.name.endsWith('.md') || e.name.endsWith('.json'))) {\n        const content = fs.readFileSync(full, 'utf-8');\n        const lines = content.split('\\n');\n        for (let i = 0; i < lines.length; i++) {\n          for (const p of patterns) {\n            if (lines[i].toLowerCase().includes(p)) {\n              results.push({file: full, line: i+1, text: lines[i].trim(), pattern: p});\n            }\n          }\n        }\n      }\n    }\n  } catch(e) {}\n  return results;\n}\n\nconst patterns = ['console.log', 'console.warn', 'console.error', 'console.info', 'console.debug', 'console.trace', 'TODO', 'FIXME', 'XXX', 'logger', 'audit', 'log('];\nconst results = searchDir('.', patterns);\n\n// Group by pattern\nconst grouped = {};\nfor (const r of results) {\n  if (!grouped[r.pattern]) grouped[r.pattern] = [];\n  grouped[r.pattern].push(r);\n}\n\nfor (const [pat, items] of Object.entries(grouped)) {\n  console.log('=== ' + pat + ' (' + items.length + ' matches) ===');\n  for (const item of items) {\n    console.log('  ' + item.file + ':' + item.line + '  ' + item.text);\n  }\n  console.log();\n}\nif (Object.keys(grouped).length === 0) console.log('No matches found.');\n\"","cwd":".","exitCode":0},"createdAt":"2026-07-01T04:02:35.099Z"}
